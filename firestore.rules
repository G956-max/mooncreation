rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: offers
    // Document ID: auto-generated
    // Fields:
    //   - title: string (required, < 100 chars)
    //   - description: string (required, < 500 chars)
    //   - imageUrl: string (required, valid URL)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: categories
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 100 chars)
    //   - imageUrl: string (required, valid URL)
    //   - subText: string (optional, < 200 chars)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: products
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required, < 100 chars)
    //   - price: number (required, > 0)
    //   - category: string (required, < 100 chars)
    //   - imageUrl: string (required, valid URL)
    //   - createdAt: timestamp (required, immutable)
    //
    // Collection: users
    // Document ID: user uid
    // Fields:
    //   - email: string
    //   - phone: string
    //   - role: string
    //   - createdAt: timestamp
    //
    // Collection: reviews
    // Document ID: auto-generated
    // Fields:
    //   - productId: string
    //   - userId: string
    //   - userName: string
    //   - rating: number (1-5)
    //   - comment: string
    //   - createdAt: timestamp
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (request.auth.token.email == "gopinathsumathi05@gmail.com" || request.auth.token.email == "admin@mooncreation.com");
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function isValidUrl(url) {
      return url is string && (url.matches("^https://.*") || url.matches("^http://.*") || url.matches("^data:image/.*"));
    }
    
    function isPositive(field) {
      return request.resource.data[field] is number && request.resource.data[field] > 0;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return hasRequiredFields(['email', 'phone', 'role', 'createdAt']) &&
             data.email is string &&
             data.phone is string &&
             (data.role == 'user' || data.role == 'admin');
    }

    function isValidOffer(data) {
      return hasOnlyAllowedFields(['title', 'description', 'imageUrl', 'createdAt']) &&
             hasRequiredFields(['title', 'description', 'imageUrl', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() < 500 &&
             isValidUrl(data.imageUrl) &&
             data.createdAt is timestamp;
    }

    function isValidCategory(data) {
      return hasOnlyAllowedFields(['name', 'imageUrl', 'subText', 'createdAt']) &&
             hasRequiredFields(['name', 'imageUrl', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             isValidUrl(data.imageUrl) &&
             (!('subText' in data) || (data.subText is string && data.subText.size() <= 200)) &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return hasOnlyAllowedFields(['name', 'description', 'price', 'comparePrice', 'costPerItem', 'sku', 'barcode', 'trackQuantity', 'availableQuantity', 'status', 'category', 'productType', 'vendor', 'collections', 'tags', 'imageUrl', 'createdAt']) &&
             hasRequiredFields(['name', 'price', 'category', 'imageUrl', 'status', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000)) &&
             isPositive('price') &&
             (!('comparePrice' in data) || data.comparePrice is number) &&
             (!('costPerItem' in data) || data.costPerItem is number) &&
             (!('sku' in data) || (data.sku is string && data.sku.size() <= 50)) &&
             (!('barcode' in data) || (data.barcode is string && data.barcode.size() <= 50)) &&
             (!('trackQuantity' in data) || data.trackQuantity is bool) &&
             (!('availableQuantity' in data) || data.availableQuantity is number) &&
             (data.status == 'draft' || data.status == 'published') &&
             data.category is string && data.category.size() > 0 && data.category.size() < 100 &&
             (!('productType' in data) || (data.productType is string && data.productType.size() <= 100)) &&
             (!('vendor' in data) || (data.vendor is string && data.vendor.size() <= 100)) &&
             (!('collections' in data) || data.collections is list) &&
             (!('tags' in data) || data.tags is list) &&
             isValidUrl(data.imageUrl) &&
             data.createdAt is timestamp;
    }

    function isValidContact(data) {
      return hasOnlyAllowedFields(['type', 'value', 'description', 'createdAt']) &&
             hasRequiredFields(['type', 'value', 'createdAt']) &&
             data.type is string && data.type.size() > 0 && data.type.size() < 50 &&
             data.value is string && data.value.size() > 0 && data.value.size() < 200 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 500)) &&
             data.createdAt is timestamp;
    }

    function isValidSetting(data) {
      return hasOnlyAllowedFields(['storeName', 'contactEmail', 'currency', 'taxRate', 'freeShippingThreshold']) &&
             hasRequiredFields(['storeName', 'contactEmail', 'currency', 'taxRate', 'freeShippingThreshold']) &&
             data.storeName is string && data.storeName.size() > 0 && data.storeName.size() < 100 &&
             data.contactEmail is string && data.contactEmail.size() > 0 && data.contactEmail.size() < 100 &&
             data.currency is string && data.currency.size() == 3 &&
             data.taxRate is number && data.taxRate >= 0 &&
             data.freeShippingThreshold is number && data.freeShippingThreshold >= 0;
    }

    function isValidDiscount(data) {
      return hasOnlyAllowedFields(['code', 'type', 'value', 'isActive', 'appliesTo', 'productIds', 'createdAt']) &&
             hasRequiredFields(['code', 'type', 'value', 'isActive', 'appliesTo', 'createdAt']) &&
             data.code is string && data.code.size() > 0 && data.code.size() < 50 &&
             (data.type == 'percentage' || data.type == 'fixed') &&
             data.value is number && data.value > 0 &&
             data.isActive is bool &&
             (data.appliesTo == 'all' || data.appliesTo == 'specific') &&
             (!('productIds' in data) || data.productIds is list) &&
             data.createdAt is timestamp;
    }

    function isValidReview(data) {
      return hasOnlyAllowedFields(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             hasRequiredFields(['productId', 'userId', 'userName', 'rating', 'comment', 'createdAt']) &&
             data.productId is string && data.productId.size() > 0 && data.productId.size() < 100 &&
             data.userId is string && data.userId.size() > 0 && data.userId.size() < 100 &&
             data.userName is string && data.userName.size() > 0 && data.userName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    function isValidBanner(data) {
      return hasOnlyAllowedFields(['image', 'title', 'subtitle']) &&
             data.image is string &&
             data.title is string &&
             data.subtitle is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if true; // Needed for phone number lookup during login
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }
    
    match /offers/{offerId} {
      allow read: if true;
      allow create: if isAdmin() && isValidOffer(request.resource.data);
      allow update: if isAdmin() && isValidOffer(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }
    
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCategory(request.resource.data);
      allow update: if isAdmin() && isValidCategory(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }
    
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }
    
    match /contacts/{contactId} {
      allow read: if true;
      allow create: if isAdmin() && isValidContact(request.resource.data);
      allow update: if isAdmin() && isValidContact(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow create: if isAdmin() && isValidSetting(request.resource.data);
      allow update: if isAdmin() && isValidSetting(request.resource.data);
      allow delete: if isAdmin();
    }

    match /discounts/{discountId} {
      allow read: if true;
      allow create: if isAdmin() && isValidDiscount(request.resource.data);
      allow update: if isAdmin() && isValidDiscount(request.resource.data) && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidReview(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && isValidReview(request.resource.data) && request.resource.data.userId == request.auth.uid && request.resource.data.createdAt == resource.data.createdAt && request.resource.data.productId == resource.data.productId;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    }

    match /banners/{bannerId} {
      allow read: if true;
      allow create: if isAdmin() && isValidBanner(request.resource.data);
      allow update: if isAdmin() && isValidBanner(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
